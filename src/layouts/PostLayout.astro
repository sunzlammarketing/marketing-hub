---
import BaseLayout from './BaseLayout.astro';
import { getCategory } from '../data/categories';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}
const { post } = Astro.props;
const { title, description, pubDate, category, tags, readingTime } =
  post.data;
const cat = getCategory(category);
const dateStr = pubDate.toLocaleDateString('vi-VN', {
  day: '2-digit',
  month: 'long',
  year: 'numeric',
});
---

<BaseLayout title={title} description={description}>
  <article class="post">
    <div class="container post-head">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/">Trang chủ</a> <span>/</span>
        <a href="/blog">Bài viết</a> <span>/</span>
        {cat && <a href={`/chu-de/${cat.slug}`}>{cat.name}</a>}
      </nav>
      {cat && (
        <a href={`/chu-de/${cat.slug}`} class="cat-chip" style={`--c:${cat.color}`}>
          {cat.icon} {cat.name}
        </a>
      )}
      <h1>{title}</h1>
      <p class="lead">{description}</p>
      <div class="byline">
        <span class="byline-meta">
          <time datetime={pubDate.toISOString()}>{dateStr}</time>
          {readingTime && <> · ⏱ {readingTime} phút đọc</>}
        </span>
      </div>
    </div>

    <div class="container post-body">
      <div class="prose">
        <slot />
      </div>

      {tags.length > 0 && (
        <div class="tags">
          {tags.map((t) => <span class="tag">#{t}</span>)}
        </div>
      )}

      <div class="post-cta">
        <a href="/blog" class="btn btn-ghost">← Xem tất cả bài viết</a>
        <a href="/lien-he" class="btn btn-primary">Liên hệ với chúng tôi</a>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .post-head {
    max-width: 760px;
    padding-top: 48px;
    text-align: center;
  }
  .crumbs {
    font-size: 0.85rem;
    color: var(--ink-faint);
    margin-bottom: 20px;
  }
  .crumbs a {
    color: var(--ink-faint);
  }
  .crumbs a:hover {
    color: var(--brand);
  }
  .crumbs span {
    margin-inline: 4px;
  }
  .cat-chip {
    display: inline-block;
    font-weight: 600;
    color: var(--c);
    background: color-mix(in srgb, var(--c) 12%, transparent);
    padding: 5px 14px;
    border-radius: 999px;
    font-size: 0.88rem;
  }
  .cat-chip:hover {
    text-decoration: none;
  }
  .post-head h1 {
    font-size: clamp(1.8rem, 4vw, 2.7rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.15;
    margin: 18px 0 14px;
  }
  .lead {
    font-size: 1.15rem;
    color: var(--ink-soft);
    margin: 0 auto 28px;
    max-width: 620px;
  }
  .byline {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4px 0 28px;
    border-bottom: 1px solid var(--border);
    width: 100%;
  }
  .byline-meta {
    font-size: 0.85rem;
    color: var(--ink-faint);
  }
  .post-body {
    max-width: 720px;
    padding-block: 40px 20px;
  }
  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 40px;
  }
  .tag {
    font-size: 0.85rem;
    color: var(--ink-soft);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    padding: 4px 12px;
    border-radius: 999px;
  }
  .post-cta {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
    justify-content: space-between;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--border);
  }
</style>
