---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-grid">
    <div class="footer-brand">
      <a href="/" class="logo">
        <span class="logo-mark">S</span>
        <span>Sunz Làm <b>Marketing</b></span>
      </a>
      <p data-i18n="footer.tagline">
        Nơi chia sẻ kiến thức Marketing dễ hiểu, thực tế và có thể áp dụng ngay.
      </p>
    </div>
  </div>
  <div class="container footer-bottom">
    <span>© {year} Sunz Làm Marketing. <span data-i18n="footer.copyright">Nội dung mang tính tham khảo & học tập.</span></span>
    <span data-i18n="footer.built">Xây dựng bằng Astro 🚀</span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--border);
    background: var(--bg-soft);
    margin-top: 40px;
  }
  .footer-grid {
    padding-block: 36px 24px;
  }
  .footer-brand p {
    color: var(--ink-soft);
    margin: 12px 0 0;
    max-width: 440px;
    font-size: 0.95rem;
  }
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
    font-weight: 800;
    font-size: 1.1rem;
  }
  .logo:hover {
    text-decoration: none;
  }
  .logo-mark {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border-radius: 8px;
    background: linear-gradient(135deg, var(--brand), var(--accent));
    color: #fff;
    font-weight: 900;
  }
  .logo b {
    color: var(--brand);
  }
  .footer-bottom {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 8px;
    padding-block: 20px;
    border-top: 1px solid var(--border);
    color: var(--ink-faint);
    font-size: 0.88rem;
  }
</style>
