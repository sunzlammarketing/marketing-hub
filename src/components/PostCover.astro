---
// Anh bia bai viet: nen gradient theo mau chu de + hoa van rieng + icon noi.
import { getCategory } from '../data/categories';

interface Props {
  category: string;
}
const { category } = Astro.props;
const cat = getCategory(category);
const color = cat?.color ?? '#4f46e5';
const icon = cat?.icon ?? '📄';
---

<div class="cover" style={`--c:${color}`}>
  <svg class="art" viewBox="0 0 400 200" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
    {/* Đốm nền mềm dùng chung */}
    <circle class="blob" cx="352" cy="34" r="74" />
    <circle class="blob2" cx="46" cy="176" r="58" />

    {category === 'nen-tang-chien-luoc' && (
      <g class="ink">
        <circle class="ring" cx="318" cy="104" r="52" />
        <circle class="ring" cx="318" cy="104" r="33" />
        <circle class="dot" cx="318" cy="104" r="12" />
        <path class="ray" d="M56 150 L128 96 L176 124 L246 62" />
        <path class="ray" d="M246 62 l-2 -20 20 6" />
      </g>
    )}

    {category === 'khach-hang' && (
      <g class="ink">
        <circle class="dot" cx="300" cy="72" r="20" />
        <path class="fill" d="M270 128 a30 26 0 0 1 60 0 z" />
        <circle class="ring" cx="348" cy="86" r="15" />
        <path class="ray" d="M330 132 a24 20 0 0 1 44 0" />
        <circle class="ring" cx="258" cy="92" r="13" />
        <path class="ray" d="M240 134 a22 18 0 0 1 40 0" />
      </g>
    )}

    {category === 'thuong-hieu' && (
      <g class="ink">
        <path class="ray" d="M310 52 l13 28 30 4 -22 22 6 30 -27 -15 -27 15 6 -30 -22 -22 30 -4 z" />
        <circle class="ring" cx="248" cy="52" r="9" />
        <circle class="dot" cx="366" cy="140" r="7" />
        <path class="ray" d="M64 156 l6 14 15 2 -11 11 3 15 -13 -7 -13 7 3 -15 -11 -11 15 -2 z" />
      </g>
    )}

    {category === 'content-social' && (
      <g class="ink">
        <rect class="fill" x="258" y="46" width="106" height="72" rx="16" />
        <path class="fill" d="M282 118 l0 22 24 -22 z" />
        <rect class="line" x="276" y="68" width="70" height="7" rx="3.5" />
        <rect class="line" x="276" y="86" width="48" height="7" rx="3.5" />
        <rect class="ring2" x="196" y="112" width="62" height="44" rx="12" />
        <rect class="line" x="210" y="128" width="34" height="6" rx="3" />
      </g>
    )}

    {category === 'seo-website' && (
      <g class="ink">
        <rect class="ring2" x="234" y="44" width="132" height="94" rx="14" />
        <rect class="line" x="248" y="58" width="44" height="7" rx="3.5" />
        <circle class="ring" cx="296" cy="102" r="27" />
        <path class="ray" d="M316 122 l24 24" />
        <rect class="line" x="60" y="150" width="70" height="7" rx="3.5" />
      </g>
    )}

    {category === 'digital' && (
      <g class="ink">
        <path class="fill" d="M254 88 l40 0 46 -28 0 88 -46 -28 -40 0 z" />
        <rect class="fill" x="262" y="92" width="16" height="34" rx="6" />
        <path class="ray" d="M352 66 a44 44 0 0 1 0 68" />
        <path class="ray" d="M368 50 a66 66 0 0 1 0 100" />
        <circle class="dot" cx="86" cy="150" r="9" />
      </g>
    )}

    {category === 'growth' && (
      <g class="ink">
        <rect class="fill" x="238" y="112" width="24" height="42" rx="7" />
        <rect class="fill" x="274" y="92" width="24" height="62" rx="7" />
        <rect class="fill" x="310" y="68" width="24" height="86" rx="7" />
        <rect class="fill" x="346" y="44" width="24" height="110" rx="7" />
        <path class="ray" d="M60 156 L128 120 L186 132 L246 88" />
        <path class="ray" d="M246 88 l-1 -19 19 7" />
      </g>
    )}

    {category === 'ecommerce-marketing' && (
      <g class="ink">
        <path class="ray" d="M244 58 l20 0 16 66 74 0 12 -44 -88 0" />
        <circle class="dot" cx="288" cy="142" r="10" />
        <circle class="dot" cx="342" cy="142" r="10" />
        <path class="ring2" d="M84 122 l30 -30 34 0 0 34 -30 30 z" />
        <circle class="dot" cx="136" cy="106" r="6" />
      </g>
    )}

    {category === 'du-lieu-do-luong' && (
      <g class="ink">
        <circle class="ring" cx="316" cy="70" r="34" />
        <path class="fill" d="M316 36 a34 34 0 0 1 34 34 l-34 0 z" />
        <rect class="fill" x="236" y="120" width="20" height="36" rx="6" />
        <rect class="fill" x="266" y="104" width="20" height="52" rx="6" />
        <rect class="fill" x="296" y="126" width="20" height="30" rx="6" />
        <rect class="fill" x="326" y="112" width="20" height="44" rx="6" />
        <path class="ray" d="M62 152 L104 128 L142 140" />
      </g>
    )}
  </svg>

  <span class="tile"><span class="emo">{icon}</span></span>
</div>

<style>
  .cover {
    position: relative;
    display: grid;
    place-items: center;
    height: 100%;
    overflow: hidden;
    background:
      linear-gradient(
        135deg,
        color-mix(in srgb, var(--c) 20%, transparent),
        color-mix(in srgb, var(--c) 5%, transparent) 55%,
        transparent
      ),
      var(--bg-soft);
  }
  .art {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  /* Hoa văn dùng màu chủ đề, độ mờ khác nhau để tạo chiều sâu */
  .blob {
    fill: var(--c);
    opacity: 0.1;
  }
  .blob2 {
    fill: var(--c);
    opacity: 0.07;
  }
  .fill {
    fill: var(--c);
    opacity: 0.2;
  }
  .line {
    fill: var(--c);
    opacity: 0.28;
  }
  .dot {
    fill: var(--c);
    opacity: 0.26;
  }
  .ring {
    fill: none;
    stroke: var(--c);
    stroke-width: 5;
    opacity: 0.26;
  }
  .ring2 {
    fill: none;
    stroke: var(--c);
    stroke-width: 5;
    opacity: 0.2;
  }
  .ray {
    fill: none;
    stroke: var(--c);
    stroke-width: 5;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: 0.3;
  }

  /* Thẻ trắng nổi chứa icon */
  .tile {
    position: relative;
    z-index: 1;
    display: grid;
    place-items: center;
    width: 68px;
    height: 68px;
    border-radius: 20px;
    background: var(--bg-card);
    border: 1px solid color-mix(in srgb, var(--c) 22%, var(--border));
    box-shadow:
      0 6px 18px color-mix(in srgb, var(--c) 22%, transparent),
      0 1px 2px rgba(0, 0, 0, 0.06);
    transition: transform 0.2s ease;
  }
  .emo {
    font-size: 1.9rem;
    line-height: 1;
  }
  :global(.card:hover) .tile {
    transform: translateY(-3px) scale(1.05);
  }
</style>
