---
// Thứ tự: Trang chủ · Giới thiệu · Bài viết · Dịch vụ · Tài liệu miễn phí · Liên hệ
const nav = [
  { href: '/', label: 'Trang chủ', key: 'nav.home' },
  { href: '/gioi-thieu', label: 'Giới thiệu', key: 'nav.about' },
  { href: '/blog', label: 'Bài viết', key: 'nav.blog' },
  { href: '/san-pham', label: 'Dịch vụ', key: 'nav.products' },
  { href: '/tai-lieu-mien-phi', label: 'Tài liệu miễn phí', key: 'nav.resources' },
  { href: '/cong-cu', label: 'Công cụ', key: 'nav.tools' },
  { href: '/lien-he', label: 'Liên hệ', key: 'nav.contact' },
];
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path.startsWith(href);
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="logo" aria-label="Sunz Làm Marketing - Trang chủ">
      <span class="logo-mark">S</span>
      <span class="logo-text">Sunz Làm <b>Marketing</b></span>
    </a>

    <nav class="nav" aria-label="Điều hướng chính">
      {
        nav.map((item) => (
          <a
            href={item.href}
            data-i18n={item.key}
            class:list={['nav-link', { active: isActive(item.href) }]}
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="header-actions">
      <!-- 1. Tìm kiếm -->
      <a href="/tim-kiem" class="icon-btn" aria-label="Tìm kiếm" data-i18n-aria="nav.search">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="11" cy="11" r="7"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </a>

      <!-- 2. Chuyển ngôn ngữ VI / EN -->
      <div class="lang">
        <button class="lang-btn" data-lang-btn aria-haspopup="true" aria-label="Ngôn ngữ" data-i18n-aria="ui.language">
          <span data-lang-flag>🇻🇳</span>
          <span data-lang-code>VI</span>
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div class="lang-menu" data-lang-menu role="menu">
          <button class="lang-item active" data-set-lang="vi" role="menuitem">
            <span>🇻🇳</span> Tiếng Việt
          </button>
          <button class="lang-item" data-set-lang="en" role="menuitem">
            <span>🇬🇧</span> English
          </button>
        </div>
      </div>

      <!-- 3. Nút chuyển sáng / tối (icon do CSS quyết định theo theme) -->
      <button
        class="icon-btn theme-btn"
        data-theme-toggle
        aria-label="Đổi giao diện sáng/tối"
        data-i18n-aria="ui.theme"
      >
        <svg data-icon-sun width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <circle cx="12" cy="12" r="4"></circle>
          <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"></path>
        </svg>
        <svg data-icon-moon width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
      </button>

      <button class="menu-toggle" aria-label="Mở menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>
  <nav class="mobile-nav" aria-label="Menu di động">
    {nav.map((item) => (
      <a href={item.href} class="mobile-link" data-i18n={item.key}>{item.label}</a>
    ))}
    <a href="/tim-kiem" class="mobile-link" data-i18n="nav.search">Tìm kiếm</a>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: saturate(180%) blur(12px);
    border-bottom: 1px solid var(--border);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 66px;
    gap: 16px;
  }
  .logo {
    display: flex;
    align-items: center;
    gap: 10px;
    color: var(--ink);
    font-weight: 800;
    font-size: 1.15rem;
    letter-spacing: -0.02em;
    white-space: nowrap;
  }
  .logo:hover {
    text-decoration: none;
  }
  .logo-mark {
    display: grid;
    place-items: center;
    width: 34px;
    height: 34px;
    border-radius: 9px;
    background: linear-gradient(135deg, var(--brand), var(--accent));
    color: #fff;
    font-weight: 900;
  }
  .logo-text b {
    color: var(--brand);
  }
  .nav {
    display: flex;
    gap: 4px;
    margin-inline: auto;
  }
  .nav-link {
    padding: 8px 14px;
    border-radius: 8px;
    color: var(--ink-soft);
    font-weight: 500;
    font-size: 0.95rem;
    white-space: nowrap;
  }
  .nav-link:hover {
    color: var(--ink);
    background: var(--bg-soft);
    text-decoration: none;
  }
  .nav-link.active {
    color: var(--brand);
    background: var(--brand-soft);
  }
  .header-actions {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .icon-btn {
    display: grid;
    place-items: center;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    color: var(--ink-soft);
    border: 1px solid var(--border);
    background: var(--bg-card);
    cursor: pointer;
  }
  .icon-btn:hover {
    color: var(--brand);
    text-decoration: none;
  }

  /* Icon nút theme: SÁNG → mặt trời, TỐI → mặt trăng. Không bao giờ hiện cả hai.
     Mặc định (sáng, hoặc HĐH sáng) chỉ hiện mặt trời. */
  .theme-btn [data-icon-sun] {
    display: block;
  }
  .theme-btn [data-icon-moon] {
    display: none;
  }
  :global(:root[data-theme='dark']) .theme-btn [data-icon-sun] {
    display: none;
  }
  :global(:root[data-theme='dark']) .theme-btn [data-icon-moon] {
    display: block;
  }
  @media (prefers-color-scheme: dark) {
    :global(:root:not([data-theme='light'])) .theme-btn [data-icon-sun] {
      display: none;
    }
    :global(:root:not([data-theme='light'])) .theme-btn [data-icon-moon] {
      display: block;
    }
  }

  /* Dropdown ngôn ngữ */
  .lang {
    position: relative;
  }
  .lang-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    height: 40px;
    padding: 0 10px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    color: var(--ink);
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
  }
  .lang-btn:hover {
    border-color: var(--brand);
  }
  .lang-btn svg:last-child {
    color: var(--ink-faint);
  }
  .lang-menu {
    position: absolute;
    top: calc(100% + 8px);
    right: 0;
    min-width: 172px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: var(--shadow-lg);
    padding: 6px;
    display: none;
    flex-direction: column;
    gap: 2px;
    z-index: 60;
  }
  .lang-menu.open {
    display: flex;
  }
  .lang-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 9px 12px;
    border-radius: 8px;
    border: none;
    background: transparent;
    color: var(--ink);
    font-size: 0.95rem;
    font-weight: 500;
    text-align: left;
    cursor: pointer;
  }
  .lang-item span {
    font-size: 1.15rem;
  }
  .lang-item:hover {
    background: var(--bg-soft);
  }
  .lang-item.active {
    background: var(--brand-soft);
    color: var(--brand);
    font-weight: 700;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    gap: 4px;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    cursor: pointer;
    align-items: center;
    justify-content: center;
  }
  .menu-toggle span {
    width: 18px;
    height: 2px;
    background: var(--ink);
    border-radius: 2px;
    transition: 0.2s;
  }
  .mobile-nav {
    display: none;
    flex-direction: column;
    padding: 8px 20px 16px;
    border-top: 1px solid var(--border);
  }
  .mobile-nav.open {
    display: flex;
  }
  .mobile-link {
    padding: 12px 8px;
    color: var(--ink);
    border-bottom: 1px solid var(--border);
    font-weight: 500;
  }
  .mobile-link:last-child {
    border-bottom: none;
  }

  @media (max-width: 1160px) {
    .nav {
      display: none;
    }
    .menu-toggle {
      display: flex;
    }
    .logo-text {
      font-size: 1.05rem;
    }
  }
  @media (max-width: 420px) {
    .lang-code-hide {
      display: none;
    }
  }
</style>

<script>
  const toggle = document.querySelector('.menu-toggle');
  const mobileNav = document.querySelector('.mobile-nav');
  toggle?.addEventListener('click', () => {
    const open = mobileNav?.classList.toggle('open');
    toggle.setAttribute('aria-expanded', String(!!open));
  });
</script>
