---
import { getCategory } from '../data/categories';

interface Props {
  slug: string;
  title: string;
  description: string;
  pubDate: Date;
  category: string;
  readingTime?: number;
  lang?: 'vi' | 'en';
}
const { slug, title, description, pubDate, category, readingTime, lang = 'vi' } =
  Astro.props;
const cat = getCategory(category);
const dateStr = pubDate.toLocaleDateString('vi-VN', {
  day: '2-digit',
  month: '2-digit',
  year: 'numeric',
});
---

<article class="card" data-post-lang={lang}>
  <a href={`/blog/${slug}`} class="card-cover" aria-hidden="true" tabindex="-1">
    <span class="cover-emoji" style={`--c:${cat?.color ?? 'var(--brand)'}`}>
      {cat?.icon ?? '📄'}
    </span>
  </a>
  <div class="card-body">
    <div class="card-meta">
      {cat && (
        <a
          href={`/chu-de/${cat.slug}`}
          class="cat-chip"
          style={`--c:${cat.color}`}
          data-i18n-vi={cat.name}
          data-i18n-en={cat.nameEn}
        >
          {lang === 'en' ? cat.nameEn : cat.name}
        </a>
      )}
      <span class="dot">·</span>
      <time datetime={pubDate.toISOString()}>{dateStr}</time>
    </div>
    <h3 class="card-title">
      <a href={`/blog/${slug}`}>{title}</a>
    </h3>
    <p class="card-desc">{description}</p>
    <div class="card-foot">
      {readingTime && (
        <span
          data-i18n-vi={`⏱ ${readingTime} phút đọc`}
          data-i18n-en={`⏱ ${readingTime} min read`}
        >
          ⏱ {readingTime} {lang === 'en' ? 'min read' : 'phút đọc'}
        </span>
      )}
      <a href={`/blog/${slug}`} class="read-more" data-i18n-vi="Đọc tiếp →" data-i18n-en="Read more →">
        {lang === 'en' ? 'Read more →' : 'Đọc tiếp →'}
      </a>
    </div>
  </div>
</article>

<style>
  .card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s;
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--brand) 40%, var(--border));
  }
  .card-cover {
    display: grid;
    place-items: center;
    height: 160px;
    background: linear-gradient(135deg, var(--bg-soft), var(--brand-soft));
  }
  .cover-emoji {
    font-size: 3rem;
    filter: drop-shadow(0 4px 12px color-mix(in srgb, var(--c) 40%, transparent));
  }
  .card-body {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 20px;
    flex: 1;
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.82rem;
    color: var(--ink-faint);
  }
  .cat-chip {
    font-weight: 600;
    color: var(--c);
    background: color-mix(in srgb, var(--c) 12%, transparent);
    padding: 3px 10px;
    border-radius: 999px;
  }
  .cat-chip:hover {
    text-decoration: none;
    background: color-mix(in srgb, var(--c) 20%, transparent);
  }
  .card-title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 700;
    line-height: 1.35;
    letter-spacing: -0.01em;
  }
  .card-title a {
    color: var(--ink);
  }
  .card-title a:hover {
    color: var(--brand);
    text-decoration: none;
  }
  .card-desc {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.95rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .card-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: 8px;
    font-size: 0.85rem;
    color: var(--ink-faint);
  }
  .read-more {
    font-weight: 600;
    font-size: 0.9rem;
  }
</style>
