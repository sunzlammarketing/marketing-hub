---
import BaseLayout from '../layouts/BaseLayout.astro';

const products = [
  { k: 'products.p1', icon: '🎓', color: '#4f46e5' },
  { k: 'products.p2', icon: '🧭', color: '#0891b2' },
  { k: 'products.p3', icon: '⭐', color: '#ca8a04' },
];
---

<BaseLayout
  title="Sản phẩm"
  description="Sản phẩm và dịch vụ của Sunz Làm Marketing: khóa học, tư vấn chiến lược và xây dựng thương hiệu."
>
  <section class="page-head">
    <div class="container">
      <span class="badge" data-i18n="products.badge">🎓 Sản phẩm & Dịch vụ</span>
      <h1 data-i18n="products.title">Sản phẩm & Dịch vụ</h1>
      <p data-i18n="products.lead">
        Các sản phẩm và dịch vụ giúp bạn học và ứng dụng Marketing hiệu quả hơn.
        (Đây là nội dung mẫu — hãy thay bằng sản phẩm thật của bạn.)
      </p>
    </div>
  </section>

  <section class="container" style="padding-block:48px 64px">
    <div class="grid grid-3">
      {products.map((p) => (
        <article class="prod-card" style={`--c:${p.color}`}>
          <span class="prod-icon">{p.icon}</span>
          <span class="prod-tag" data-i18n="products.badge2">Nội dung mẫu</span>
          <h3 data-i18n={`${p.k}.name`}>Sản phẩm</h3>
          <p data-i18n={`${p.k}.desc`}>Mô tả sản phẩm.</p>
          <div class="prod-foot">
            <span class="prod-price" data-i18n={`${p.k}.price`}>Đang cập nhật</span>
            <a href="/lien-he" class="btn btn-primary prod-btn" data-i18n="products.cta">Liên hệ tư vấn</a>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-block: 56px 32px;
    text-align: center;
    background: var(--bg-soft);
    border-bottom: 1px solid var(--border);
  }
  .page-head h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 16px 0 8px;
  }
  .page-head p {
    color: var(--ink-soft);
    margin: 0 auto;
    max-width: 620px;
  }
  .prod-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 28px 24px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s;
  }
  .prod-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--c) 45%, var(--border));
  }
  .prod-icon {
    font-size: 2rem;
    width: 60px;
    height: 60px;
    display: grid;
    place-items: center;
    border-radius: 14px;
    background: color-mix(in srgb, var(--c) 12%, transparent);
  }
  .prod-tag {
    position: absolute;
    top: 18px;
    right: 18px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    padding: 3px 9px;
    border-radius: 999px;
  }
  .prod-card h3 {
    margin: 4px 0 0;
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--ink);
  }
  .prod-card p {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.95rem;
    flex: 1;
  }
  .prod-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 8px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }
  .prod-price {
    font-weight: 700;
    color: var(--c);
    font-size: 0.95rem;
  }
  .prod-btn {
    padding: 8px 16px;
    font-size: 0.88rem;
  }
</style>
