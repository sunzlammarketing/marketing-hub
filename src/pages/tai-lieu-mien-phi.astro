---
import BaseLayout from '../layouts/BaseLayout.astro';

const docs = [
  { k: 'resources.d1', icon: '📘', color: '#4f46e5' },
  { k: 'resources.d2', icon: '✅', color: '#0891b2' },
  { k: 'resources.d3', icon: '🗓️', color: '#ea580c' },
  { k: 'resources.d4', icon: '📣', color: '#dc2626' },
];
---

<BaseLayout
  title="Tài liệu miễn phí"
  description="Tài liệu Marketing miễn phí của Sunz Làm Marketing: ebook, checklist và template giúp bạn học và làm Marketing hiệu quả hơn."
>
  <section class="page-head">
    <div class="container">
      <span class="badge" data-i18n="resources.badge">📂 Tài liệu miễn phí</span>
      <h1 data-i18n="resources.title">Tài liệu Marketing miễn phí</h1>
      <p data-i18n="resources.lead">
        Tổng hợp ebook, checklist và template giúp bạn học và làm Marketing hiệu
        quả hơn. (Đây là nội dung mẫu — hãy thay bằng tài liệu thật của bạn.)
      </p>
    </div>
  </section>

  <section class="container" style="padding-block:48px 64px">
    <div class="docs-grid">
      {docs.map((d) => (
        <article class="doc-card" style={`--c:${d.color}`}>
          <div class="doc-top">
            <span class="doc-icon">{d.icon}</span>
            <span class="doc-tag" data-i18n="resources.badge2">Mẫu</span>
          </div>
          <h3 data-i18n={`${d.k}.name`}>Tài liệu</h3>
          <p data-i18n={`${d.k}.desc`}>Mô tả tài liệu.</p>
          <div class="doc-foot">
            <span class="doc-type" data-i18n={`${d.k}.type`}>PDF</span>
            <button class="btn btn-primary doc-btn" data-demo-download data-i18n="resources.download">
              Tải xuống
            </button>
          </div>
        </article>
      ))}
    </div>
    <p id="demo-note" class="demo-note" hidden></p>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-block: 56px 32px;
    text-align: center;
    background: var(--bg-soft);
    border-bottom: 1px solid var(--border);
  }
  .page-head h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 16px 0 8px;
  }
  .page-head p {
    color: var(--ink-soft);
    margin: 0 auto;
    max-width: 640px;
  }
  .docs-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
  .doc-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: 24px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s;
  }
  .doc-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
    border-color: color-mix(in srgb, var(--c) 45%, var(--border));
  }
  .doc-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .doc-icon {
    font-size: 1.6rem;
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    border-radius: 12px;
    background: color-mix(in srgb, var(--c) 12%, transparent);
  }
  .doc-tag {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--ink-faint);
    background: var(--bg-soft);
    border: 1px solid var(--border);
    padding: 3px 9px;
    border-radius: 999px;
  }
  .doc-card h3 {
    margin: 4px 0 0;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--ink);
  }
  .doc-card p {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.95rem;
    flex: 1;
  }
  .doc-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 8px;
    padding-top: 14px;
    border-top: 1px solid var(--border);
  }
  .doc-type {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--ink-faint);
  }
  .doc-btn {
    padding: 8px 16px;
    font-size: 0.88rem;
  }
  .demo-note {
    margin-top: 24px;
    text-align: center;
    color: var(--ink-faint);
    font-size: 0.92rem;
  }
  @media (max-width: 640px) {
    .docs-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  // Bản mẫu: nút tải xuống chưa gắn file thật. Hiện thông báo nhắc thay file.
  const note = document.getElementById('demo-note');
  const msg = {
    vi: '📄 Đây là tài liệu mẫu — hãy tải file thật lên và gắn link tải cho từng thẻ.',
    en: '📄 This is a sample resource — upload your real files and link them on each card.',
  };
  document.querySelectorAll('[data-demo-download]').forEach((btn) => {
    btn.addEventListener('click', () => {
      if (!note) return;
      const lang = document.documentElement.getAttribute('lang') === 'en' ? 'en' : 'vi';
      note.textContent = msg[lang];
      note.hidden = false;
    });
  });
</script>
