---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Công cụ kiểm tra content quảng cáo"
  description="Công cụ miễn phí rà soát nội dung quảng cáo, phát hiện từ ngữ dễ vi phạm chính sách Facebook và Luật Quảng cáo Việt Nam."
>
  <section class="page-head">
    <div class="container">
      <h1 data-i18n="tools.title">Kiểm tra content quảng cáo</h1>
      <p data-i18n="tools.lead">
        Dán nội dung quảng cáo của bạn để rà soát nhanh những từ ngữ dễ vi phạm
        chính sách Facebook và Luật Quảng cáo Việt Nam, kèm gợi ý sửa.
      </p>
    </div>
  </section>

  <section class="container tool-wrap">
    <div class="tool-card">
      <label class="field-label" for="ad-content" data-i18n="tools.input.label">
        Nội dung quảng cáo
      </label>
      <textarea
        id="ad-content"
        rows="9"
        placeholder="Dán toàn bộ nội dung bài quảng cáo vào đây, gồm cả câu kêu gọi hành động (Mua ngay, Inbox tư vấn...)"
        data-i18n-ph="tools.input.ph"></textarea>

      <label class="check">
        <input type="checkbox" id="opt-vn" checked />
        <span data-i18n="tools.opt.vn">Kiểm tra thêm theo Luật Quảng cáo Việt Nam</span>
      </label>

      <button id="run" class="btn btn-primary run-btn" data-i18n="tools.btn">
        Kiểm tra ngay
      </button>
    </div>

    <div id="result" class="result" hidden></div>

    <p class="disclaimer" data-i18n="tools.disclaimer">
      Công cụ rà soát sơ bộ theo danh sách từ ngữ rủi ro thường gặp. Kết quả mang
      tính tham khảo, không thay thế tư vấn pháp lý hay quyết định duyệt của Facebook.
    </p>
    <p class="ai-note" data-i18n="tools.aiNote">
      Sắp có: lớp phân tích bằng AI để hiểu ngữ cảnh cả bài, không chỉ dò từ khóa.
    </p>
  </section>
</BaseLayout>

<style>
  .page-head {
    padding-block: 56px 32px;
    text-align: center;
    background: var(--bg-soft);
    border-bottom: 1px solid var(--border);
  }
  .page-head h1 {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 10px;
  }
  .page-head p {
    color: var(--ink-soft);
    margin: 0 auto;
    max-width: 660px;
  }
  .tool-wrap {
    max-width: 820px;
    padding-block: 40px 64px;
  }
  .tool-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 18px;
    padding: 26px;
    box-shadow: var(--shadow);
  }
  .field-label {
    display: block;
    font-weight: 700;
    font-size: 0.95rem;
    margin-bottom: 8px;
  }
  textarea {
    width: 100%;
    padding: 14px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--bg);
    color: var(--ink);
    font-family: inherit;
    font-size: 0.98rem;
    line-height: 1.6;
    resize: vertical;
  }
  textarea:focus {
    outline: none;
    border-color: var(--brand);
  }
  .check {
    display: flex;
    align-items: center;
    gap: 9px;
    margin: 16px 0 20px;
    font-size: 0.94rem;
    color: var(--ink-soft);
    cursor: pointer;
  }
  .check input {
    width: 17px;
    height: 17px;
    accent-color: var(--brand);
    cursor: pointer;
  }
  .run-btn {
    width: 100%;
    justify-content: center;
  }

  .result {
    margin-top: 28px;
  }
  .summary {
    display: flex;
    align-items: center;
    gap: 14px;
    flex-wrap: wrap;
    padding: 18px 20px;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: var(--bg-card);
    margin-bottom: 18px;
  }
  .risk-badge {
    font-weight: 800;
    font-size: 0.95rem;
    padding: 7px 16px;
    border-radius: 999px;
    color: #fff;
  }
  .risk-high { background: #dc2626; }
  .risk-medium { background: #ea580c; }
  .risk-low { background: #ca8a04; }
  .risk-none { background: #16a34a; }
  .summary-text {
    color: var(--ink-soft);
    font-size: 0.95rem;
  }

  .finding {
    border: 1px solid var(--border);
    border-left: 4px solid var(--sev);
    border-radius: 12px;
    background: var(--bg-card);
    padding: 16px 18px;
    margin-bottom: 12px;
  }
  .f-top {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    margin-bottom: 8px;
  }
  .sev-tag {
    font-size: 0.72rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--sev);
    background: color-mix(in srgb, var(--sev) 12%, transparent);
    padding: 3px 10px;
    border-radius: 999px;
  }
  .f-match {
    font-weight: 700;
    color: var(--ink);
  }
  .f-match code {
    background: color-mix(in srgb, var(--sev) 12%, transparent);
    color: var(--sev);
    padding: 2px 8px;
    border-radius: 6px;
    font-size: 0.92rem;
  }
  .f-reason {
    color: var(--ink-soft);
    font-size: 0.94rem;
    margin: 0 0 8px;
  }
  .f-fix {
    font-size: 0.94rem;
    color: var(--ink);
    background: var(--bg-soft);
    border-radius: 8px;
    padding: 10px 12px;
  }
  .f-fix b {
    color: var(--brand);
  }
  .pass-msg {
    padding: 20px;
    border-radius: 14px;
    background: color-mix(in srgb, #16a34a 10%, transparent);
    border: 1px solid color-mix(in srgb, #16a34a 35%, transparent);
    color: var(--ink);
    font-size: 0.98rem;
  }
  .disclaimer,
  .ai-note {
    margin-top: 22px;
    font-size: 0.87rem;
    color: var(--ink-faint);
    text-align: center;
  }
  .ai-note {
    margin-top: 8px;
    color: var(--brand);
    font-weight: 600;
  }
</style>

<script>
  type Sev = 'high' | 'medium' | 'low';
  interface Rule {
    sev: Sev;
    vnOnly?: boolean; // chỉ áp dụng khi bật kiểm tra Luật Quảng cáo VN
    patterns: string[];
    reason: { vi: string; en: string };
    fix: { vi: string; en: string };
  }

  // ====== Danh sách từ ngữ rủi ro. Bổ sung/sửa tự do tại đây. ======
  const RULES: Rule[] = [
    {
      sev: 'high',
      vnOnly: true,
      patterns: ['so 1', 'so mot', 'tot nhat', 'duy nhat', 'hang dau', 'nhat viet nam', 'dung dau', 'vo dich'],
      reason: {
        vi: 'Luật Quảng cáo Việt Nam cấm dùng từ “nhất”, “duy nhất”, “tốt nhất”, “số một” nếu không có tài liệu hợp pháp chứng minh.',
        en: 'Vietnamese advertising law prohibits superlatives such as "best", "number one", "only" without legal documentation to prove it.',
      },
      fix: {
        vi: 'Thay bằng mô tả cụ thể, có thể kiểm chứng: “được hơn 2.000 khách hàng lựa chọn”, “top 3 theo khảo sát X”.',
        en: 'Replace with specific, verifiable claims: "chosen by 2,000+ customers", "top 3 according to survey X".',
      },
    },
    {
      sev: 'high',
      patterns: ['cam ket 100', 'dam bao 100', 'hieu qua 100', '100% hieu qua', 'chac chan khoi', 'tuyet doi an toan'],
      reason: {
        vi: 'Cam kết tuyệt đối (100%, chắc chắn) là tuyên bố không thể chứng minh, dễ bị Facebook từ chối và vi phạm quy định quảng cáo.',
        en: 'Absolute guarantees (100%, guaranteed) are unprovable claims that Facebook commonly rejects and that breach advertising rules.',
      },
      fix: {
        vi: 'Dùng ngôn ngữ có giới hạn: “đa số khách hàng thấy cải thiện sau 4 tuần”, “hỗ trợ đổi trả trong 7 ngày”.',
        en: 'Use qualified language: "most customers see improvement after 4 weeks", "7-day return support".',
      },
    },
    {
      sev: 'high',
      patterns: ['chua khoi', 'tri dut diem', 'dac tri', 'khoi benh', 'than duoc', 'thay the thuoc', 'diet tan goc', 'chua benh'],
      reason: {
        vi: 'Tuyên bố chữa bệnh cho sản phẩm không phải thuốc bị cấm. Thực phẩm chức năng, mỹ phẩm không được quảng cáo như thuốc chữa bệnh.',
        en: 'Claiming a non-medicine product cures disease is prohibited. Supplements and cosmetics may not be advertised as medical treatments.',
      },
      fix: {
        vi: 'Chuyển sang mô tả công dụng hỗ trợ: “hỗ trợ giảm cảm giác khó chịu”, kèm dòng “Sản phẩm không phải là thuốc và không có tác dụng thay thế thuốc chữa bệnh”.',
        en: 'Describe supportive benefits instead, and add the required note that the product is not a medicine and does not replace medical treatment.',
      },
    },
    {
      sev: 'high',
      patterns: ['ban bi ', 'ban dang bi', 'ban co bi', 'ban beo', 'ban hoi', 'ban mat ngu', 'ban ngheo', 'ban that bai'],
      reason: {
        vi: 'Chính sách “Đặc điểm cá nhân” của Facebook cấm nội dung ám chỉ trực tiếp tình trạng cá nhân của người xem (bệnh tật, ngoại hình, tài chính...).',
        en: 'Facebook\'s Personal Attributes policy prohibits copy that directly implies the viewer\'s personal condition (health, appearance, finances...).',
      },
      fix: {
        vi: 'Chuyển sang ngôi thứ ba hoặc nói chung: “Nhiều người gặp tình trạng mất ngủ kéo dài...” thay vì “Bạn đang bị mất ngủ?”.',
        en: 'Switch to third person or general phrasing: "Many people struggle with insomnia..." instead of "Are you suffering from insomnia?".',
      },
    },
    {
      sev: 'high',
      patterns: ['lam giau', 'thu nhap khung', 'kiem tien nhanh', 'viec nhe luong cao', 'khong can von', 'x2 tai khoan', 'loi nhuan cao'],
      reason: {
        vi: 'Hứa hẹn thu nhập/lợi nhuận phi thực tế là dạng nội dung gây hiểu lầm, thường bị từ chối và có rủi ro pháp lý.',
        en: 'Unrealistic income or profit promises are misleading content, commonly rejected and legally risky.',
      },
      fix: {
        vi: 'Nêu con số có bối cảnh và điều kiện: “doanh thu tham khảo của học viên A sau 6 tháng, kết quả tùy năng lực và thị trường”.',
        en: 'State figures with context and conditions: "reference revenue of student A after 6 months; results vary by skill and market".',
      },
    },
    {
      sev: 'medium',
      patterns: ['giam can cap toc', 'giam beo cap toc', 'eo thon sau', 'giam 5kg', 'giam 10kg', 'giam mo cap toc'],
      reason: {
        vi: 'Quảng cáo giảm cân với kết quả nhanh/cụ thể bị Facebook hạn chế mạnh và dễ bị coi là gây hiểu lầm.',
        en: 'Weight-loss ads promising fast or specific results are heavily restricted by Facebook and easily seen as misleading.',
      },
      fix: {
        vi: 'Tập trung vào thói quen và quá trình thay vì con số: “xây dựng thực đơn khoa học, duy trì đều đặn”.',
        en: 'Focus on habits and process rather than numbers: "build a balanced meal plan and stay consistent".',
      },
    },
    {
      sev: 'medium',
      patterns: ['truoc va sau', 'before after', 'lot xac', 'anh truoc sau'],
      reason: {
        vi: 'Hình ảnh/nội dung “trước và sau” bị Facebook hạn chế vì tạo kỳ vọng không thực tế về kết quả.',
        en: 'Before-and-after content is restricted by Facebook because it creates unrealistic expectations of results.',
      },
      fix: {
        vi: 'Thay bằng ảnh sản phẩm, quy trình sử dụng, hoặc cảm nhận khách hàng dưới dạng lời kể.',
        en: 'Use product photos, the usage process, or written customer testimonials instead.',
      },
    },
    {
      sev: 'medium',
      vnOnly: true,
      patterns: ['hon han', 'vuot troi hon', 'danh bai', 'tot hon hang', 'hon doi thu'],
      reason: {
        vi: 'Luật Quảng cáo Việt Nam cấm so sánh trực tiếp sản phẩm của mình với sản phẩm cùng loại của tổ chức, cá nhân khác.',
        en: 'Vietnamese advertising law prohibits directly comparing your product against a competitor\'s comparable product.',
      },
      fix: {
        vi: 'Nói về ưu điểm của chính bạn mà không quy chiếu đối thủ: “công thức có thêm thành phần X giúp...”.',
        en: 'Highlight your own strengths without referencing competitors: "our formula adds ingredient X which helps...".',
      },
    },
    {
      sev: 'low',
      patterns: ['soc', 'kinh hoang', 'bi mat dong troi', 'canh bao khan', 'khong the tin noi', 'gay bao'],
      reason: {
        vi: 'Ngôn từ giật gân dễ bị đánh giá là nội dung câu view, làm giảm điểm chất lượng quảng cáo.',
        en: 'Sensational wording is easily judged as clickbait and can lower your ad quality score.',
      },
      fix: {
        vi: 'Dùng tiêu đề nêu lợi ích cụ thể thay vì gây sốc: “3 cách giảm chi phí quảng cáo trong 30 ngày”.',
        en: 'Use a concrete benefit headline instead of shock: "3 ways to cut ad costs in 30 days".',
      },
    },
    {
      sev: 'low',
      patterns: ['mien phi 100', 'hoan toan mien phi', 'tang 100'],
      reason: {
        vi: 'Nếu vẫn có bất kỳ chi phí nào (ship, phụ phí, điều kiện kèm theo), tuyên bố “miễn phí hoàn toàn” bị coi là gây hiểu lầm.',
        en: 'If any cost remains (shipping, fees, conditions), claiming "completely free" is considered misleading.',
      },
      fix: {
        vi: 'Ghi rõ điều kiện: “miễn phí buổi tư vấn đầu tiên”, “freeship cho đơn từ 300k”.',
        en: 'State the conditions: "first consultation free", "free shipping on orders over 300k".',
      },
    },
  ];

  const $ = (s: string) => document.querySelector(s);
  const box = $('#ad-content') as HTMLTextAreaElement;
  const optVn = $('#opt-vn') as HTMLInputElement;
  const runBtn = $('#run') as HTMLButtonElement;
  const result = $('#result') as HTMLElement;

  const curLang = (): 'vi' | 'en' =>
    document.documentElement.getAttribute('lang') === 'en' ? 'en' : 'vi';

  const t = (key: string): string => {
    const dict = (window as any).__I18N__ || {};
    const l = curLang();
    return (dict[l] && dict[l][key]) || (dict.vi && dict.vi[key]) || '';
  };

  // Bỏ dấu tiếng Việt để so khớp linh hoạt
  const norm = (s: string) =>
    s
      .toLowerCase()
      .normalize('NFD')
      .replace(/[\u0300-\u036f]/g, "")
      .replace(/đ/g, 'd')
      .replace(/\s+/g, ' ');

  // Chuẩn hoá nhưng vẫn nhớ vị trí gốc, để trích đúng cụm chữ người dùng đã viết
  function normWithMap(s: string) {
    let out = '';
    const map: number[] = [];
    for (let i = 0; i < s.length; i++) {
      const piece = norm(s[i]);
      for (let k = 0; k < piece.length; k++) {
        out += piece[k];
        map.push(i);
      }
    }
    return { out, map };
  }

  // Trích cụm chữ gốc tương ứng với vị trí khớp trong chuỗi đã chuẩn hoá
  function originalSlice(raw: string, map: number[], start: number, len: number) {
    const from = map[start];
    const to = map[start + len - 1];
    if (from === undefined || to === undefined) return '';
    return raw.slice(from, to + 1);
  }

  const escapeHtml = (s: string) =>
    s.replace(/[&<>"]/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' })[c] || c
    );

  const SEV_COLOR: Record<Sev, string> = {
    high: '#dc2626',
    medium: '#ea580c',
    low: '#ca8a04',
  };

  function analyze() {
    const raw = box.value.trim();
    const lang = curLang();

    if (!raw) {
      result.hidden = false;
      result.innerHTML = `<div class="summary"><span class="summary-text">${escapeHtml(t('tools.empty'))}</span></div>`;
      return;
    }

    const { out: text, map } = normWithMap(raw);
    const includeVn = optVn.checked;

    // Tìm các quy tắc bị vi phạm, lấy đúng cụm chữ gốc trong bài
    const findings: { rule: Rule; hits: string[] }[] = [];
    for (const rule of RULES) {
      if (rule.vnOnly && !includeVn) continue;
      const hits: string[] = [];
      for (const p of rule.patterns) {
        const np = norm(p);
        const idx = text.indexOf(np);
        if (idx === -1) continue;
        const original = originalSlice(raw, map, idx, np.length).trim();
        hits.push(original || p);
      }
      if (hits.length) findings.push({ rule, hits });
    }

    // Xếp theo mức độ nghiêm trọng
    const order: Record<Sev, number> = { high: 0, medium: 1, low: 2 };
    findings.sort((a, b) => order[a.rule.sev] - order[b.rule.sev]);

    result.hidden = false;

    if (!findings.length) {
      result.innerHTML = `
        <div class="summary">
          <span class="risk-badge risk-none">${escapeHtml(t('tools.risk.none'))}</span>
          <span class="summary-text">${escapeHtml(t('tools.result.title'))}</span>
        </div>
        <div class="pass-msg">${escapeHtml(t('tools.pass'))}</div>`;
      return;
    }

    const worst: Sev = findings[0].rule.sev;
    const riskKey =
      worst === 'high' ? 'high' : worst === 'medium' ? 'medium' : 'low';

    const cards = findings
      .map(({ rule, hits }) => {
        const color = SEV_COLOR[rule.sev];
        const chips = hits
          .map((h) => `<code>${escapeHtml(h)}</code>`)
          .join(' ');
        return `
        <div class="finding" style="--sev:${color}">
          <div class="f-top">
            <span class="sev-tag">${escapeHtml(t('tools.sev.' + rule.sev))}</span>
            <span class="f-match">${escapeHtml(t('tools.matched'))}: ${chips}</span>
          </div>
          <p class="f-reason">${escapeHtml(rule.reason[lang])}</p>
          <div class="f-fix"><b>${escapeHtml(t('tools.fixLabel'))}:</b> ${escapeHtml(rule.fix[lang])}</div>
        </div>`;
      })
      .join('');

    result.innerHTML = `
      <div class="summary">
        <span class="risk-badge risk-${riskKey}">${escapeHtml(t('tools.riskLabel'))}: ${escapeHtml(t('tools.risk.' + riskKey))}</span>
        <span class="summary-text">${findings.length} ${escapeHtml(t('tools.foundOne'))}</span>
      </div>
      ${cards}`;
  }

  runBtn?.addEventListener('click', analyze);
  // Đổi ngôn ngữ thì hiển thị lại kết quả bằng ngôn ngữ mới
  document.addEventListener('langchange', () => {
    if (!result.hidden) analyze();
  });
</script>
