---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { categories } from '../data/categories';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const featured = posts[0];
const recent = posts.slice(1, 7);
---

<BaseLayout title="Sunz Làm Marketing">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <h1 data-i18n-html="home.hero.title">
          Hiểu Marketing <span class="grad">đúng</span>,<br />
          làm Marketing <span class="grad">hiệu quả</span>.
        </h1>
        <p class="hero-sub" data-i18n="home.hero.sub">
          Kiến thức Marketing dễ hiểu, thực tế và có thể áp dụng xuyên suốt hành
          trình Marketing từ nghiên cứu thị trường, xây dựng chiến lược đến triển
          khai, đo lường và tối ưu hiệu quả.
        </p>
        <div class="hero-actions">
          <a href="/blog" class="btn btn-primary" data-i18n="home.hero.cta1">Bắt đầu đọc →</a>
          <a href="/chu-de" class="btn btn-ghost" data-i18n="home.hero.cta2">Khám phá chủ đề</a>
        </div>
      </div>

      <div class="hero-media">
        <span class="hero-media-note">
          🖼️ Thêm ảnh banner vào <b>public/hero-banner.png</b> để hiển thị ở đây
        </span>
        <img
          src="/hero-banner.png"
          alt="Sunz Làm Marketing"
          loading="eager"
          onerror="this.style.display='none'; this.parentElement.classList.add('no-img')"
        />
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="section">
    <div class="container">
      <h2 class="section-title" data-i18n="home.cat.title">Khám phá theo chủ đề</h2>
      <p class="section-sub" data-i18n="home.cat.sub">
        Chọn lĩnh vực bạn quan tâm và đào sâu vào những bài viết chất lượng.
      </p>
      <div class="cat-grid">
        {categories.map((c) => (
          <a href={`/chu-de/${c.slug}`} class="cat-card" style={`--c:${c.color}`}>
            <span class="cat-icon">{c.icon}</span>
            <span class="cat-name" data-i18n-vi={c.name} data-i18n-en={c.nameEn}>{c.name}</span>
            <span class="cat-desc" data-i18n-vi={c.description} data-i18n-en={c.descriptionEn}>{c.description}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured -->
  {featured && (
    <section class="section featured-section">
      <div class="container">
        <h2 class="section-title" data-i18n="home.featured.title">Bài viết nổi bật</h2>
        <p class="section-sub" data-i18n="home.featured.sub">Bài viết mới nhất, đáng đọc nhất tuần này.</p>
        <div class="featured-wrap">
          <PostCard
            slug={featured.slug}
            title={featured.data.title}
            description={featured.data.description}
            pubDate={featured.data.pubDate}
            category={featured.data.category}
            readingTime={featured.data.readingTime}
            featured={true}
          />
        </div>
      </div>
    </section>
  )}

  <!-- Recent -->
  <section class="section">
    <div class="container">
      <div class="row-head">
        <div>
          <h2 class="section-title" data-i18n="home.recent.title">Bài viết mới nhất</h2>
          <p class="section-sub" style="margin-bottom:0" data-i18n="home.recent.sub">
            Cập nhật kiến thức marketing đều đặn mỗi tuần.
          </p>
        </div>
        <a href="/blog" class="btn btn-ghost" data-i18n="home.viewall">Xem tất cả →</a>
      </div>
      <div class="grid grid-3" style="margin-top:32px">
        {recent.map((p) => (
          <PostCard
            slug={p.slug}
            title={p.data.title}
            description={p.data.description}
            pubDate={p.data.pubDate}
            category={p.data.category}
            readingTime={p.data.readingTime}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-box">
        <h2 data-i18n="home.cta.title">Đừng bỏ lỡ kiến thức mới</h2>
        <p data-i18n="home.cta.text">
          Ghé thăm thường xuyên hoặc kết nối với chúng tôi để cập nhật những
          bài viết marketing mới nhất.
        </p>
        <a href="/lien-he" class="btn btn-primary" data-i18n="home.cta.btn">Kết nối ngay →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding-block: 60px 56px;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(50% 60% at 70% 10%, var(--brand-soft), transparent 70%);
    z-index: -1;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: center;
    gap: 48px;
  }
  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }
  .hero h1 {
    font-size: clamp(2rem, 4.4vw, 3.35rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 0;
    text-align: left;
  }
  .grad {
    background: linear-gradient(120deg, var(--brand), var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-sub {
    font-size: 1.12rem;
    color: var(--ink-soft);
    max-width: 540px;
    margin: 0;
  }
  .hero-actions {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }
  .hero-media {
    position: relative;
    display: grid;
    place-items: center;
    border-radius: 22px;
    overflow: hidden;
    background: linear-gradient(135deg, var(--brand-soft), var(--bg-soft));
    box-shadow: var(--shadow);
  }
  /* Khi chưa có ảnh: hiện khung gợi ý có viền đứt */
  .hero-media.no-img {
    min-height: 300px;
    border: 2px dashed color-mix(in srgb, var(--brand) 35%, var(--border));
    box-shadow: none;
  }
  .hero-media img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: auto;
    display: block;
  }
  .hero-media-note {
    position: absolute;
    z-index: 0;
    padding: 70px 24px;
    text-align: center;
    color: var(--ink-faint);
    font-size: 0.9rem;
    line-height: 1.5;
  }
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .hero-text {
      align-items: center;
      text-align: center;
    }
    .hero h1 {
      text-align: center;
    }
    .hero-actions {
      justify-content: center;
    }
  }
  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .cat-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s;
  }
  .cat-card:hover {
    text-decoration: none;
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: color-mix(in srgb, var(--c) 45%, var(--border));
  }
  .cat-icon {
    font-size: 1.8rem;
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    border-radius: 12px;
    background: color-mix(in srgb, var(--c) 12%, transparent);
  }
  .cat-name {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--ink);
  }
  .cat-desc {
    color: var(--ink-soft);
    font-size: 0.92rem;
  }

  .featured-section {
    background: var(--bg-soft);
    border-block: 1px solid var(--border);
  }
  .featured-wrap {
    max-width: 720px;
  }

  .row-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .cta-box {
    text-align: center;
    padding: 56px 24px;
    border-radius: 24px;
    background: linear-gradient(135deg, var(--brand), var(--accent));
    color: #fff;
  }
  .cta-box h2 {
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 800;
    margin: 0 0 10px;
  }
  .cta-box p {
    max-width: 500px;
    margin: 0 auto 24px;
    opacity: 0.95;
  }
  .cta-box .btn-primary {
    background: #fff;
    color: var(--brand-dark);
  }
  .cta-box .btn-primary:hover {
    background: #f0f0f0;
  }

  @media (max-width: 860px) {
    .cat-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .cat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
