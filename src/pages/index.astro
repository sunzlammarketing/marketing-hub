---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { categories } from '../data/categories';
import { getCollection } from 'astro:content';

const all = await getCollection('blog');
const byLang = (l: 'vi' | 'en') =>
  all
    .filter((p) => p.data.lang === l)
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
const viPosts = byLang('vi');
const enPosts = byLang('en');
// Render cả hai ngôn ngữ; runtime i18n sẽ ẩn nhóm không khớp ngôn ngữ đang chọn.
// Mỗi mục chỉ hiển thị 3 bài (đúng 1 hàng ngang)
const featured = [...viPosts.slice(0, 3), ...enPosts.slice(0, 3)];
const recent = [...viPosts.slice(3, 6), ...enPosts.slice(3, 6)];
---

<BaseLayout title="Sunz Làm Marketing">
  <!-- Hero -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-text">
        <h1 data-i18n-html="home.hero.title">
          Hiểu Marketing <span class="grad">đúng</span>,<br />
          làm Marketing <span class="grad">hiệu quả</span>.
        </h1>
        <p class="hero-sub" data-i18n="home.hero.sub">
          Kiến thức Marketing dễ hiểu, thực tế và có thể áp dụng xuyên suốt hành
          trình Marketing từ nghiên cứu thị trường, xây dựng chiến lược đến triển
          khai, đo lường và tối ưu hiệu quả.
        </p>
        <div class="hero-actions">
          <a href="/tai-lieu-mien-phi" class="btn btn-primary cta-main" data-i18n="home.hero.cta1">
            Kho tài liệu Marketing miễn phí
          </a>
          <a href="#sunz-la-ai" class="btn btn-ghost cta-sub" data-i18n="home.hero.cta2">
            Sunz Làm Marketing là ai?
          </a>
        </div>
      </div>

      <div class="hero-media">
        <svg class="hero-illus" viewBox="0 0 500 430" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Minh họa Sunz Làm Marketing">
          <defs>
            <linearGradient id="hbg" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0" stop-color="#4f46e5" />
              <stop offset="0.55" stop-color="#6d5df0" />
              <stop offset="1" stop-color="#06b6d4" />
            </linearGradient>
          </defs>

          <!-- Nền thẻ + hoa văn -->
          <rect x="0" y="0" width="500" height="430" rx="26" fill="url(#hbg)" />
          <circle cx="446" cy="58" r="92" fill="#ffffff" opacity="0.10" />
          <circle cx="52" cy="392" r="74" fill="#ffffff" opacity="0.08" />

          <!-- Pill chủ đề -->
          <g font-family="Inter, sans-serif" font-weight="700" font-size="15">
            <rect x="40" y="42" width="86" height="34" rx="17" fill="#ffffff" />
            <text x="83" y="64" text-anchor="middle" fill="#2563eb">SEO</text>
            <rect x="140" y="66" width="126" height="34" rx="17" fill="#ffffff" opacity="0.94" />
            <text x="203" y="88" text-anchor="middle" fill="#7c3aed">Content</text>
            <rect x="336" y="40" width="120" height="34" rx="17" fill="#ffffff" opacity="0.94" />
            <text x="396" y="62" text-anchor="middle" fill="#16a34a">Growth</text>
          </g>

          <!-- Thẻ biểu đồ -->
          <rect x="70" y="126" width="360" height="196" rx="20" fill="#ffffff" />
          <rect x="110" y="248" width="42" height="50" rx="9" fill="#c7d2fe" />
          <rect x="172" y="222" width="42" height="76" rx="9" fill="#a5b4fc" />
          <rect x="234" y="196" width="42" height="102" rx="9" fill="#818cf8" />
          <rect x="296" y="162" width="42" height="136" rx="9" fill="#4f46e5" />
          <!-- Đường xu hướng đi lên -->
          <polyline points="131,238 193,212 255,186 317,152" fill="none" stroke="#06b6d4" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" />
          <circle cx="131" cy="238" r="5" fill="#06b6d4" />
          <circle cx="193" cy="212" r="5" fill="#06b6d4" />
          <circle cx="255" cy="186" r="5" fill="#06b6d4" />
          <circle cx="317" cy="152" r="5.5" fill="#06b6d4" />
          <path d="M317 152 l16 -3 -6 15 z" fill="#06b6d4" />

          <!-- Huy hiệu tim (like) -->
          <circle cx="96" cy="140" r="24" fill="#ec4899" />
          <path d="M96 150 c-8 -6 -13 -11 -13 -17 a5.5 5.5 0 0 1 10 -3 a5.5 5.5 0 0 1 10 3 c0 6 -5 11 -13 17 z" fill="#ffffff" />
          <!-- Huy hiệu loa (megaphone) -->
          <circle cx="410" cy="300" r="27" fill="#f59e0b" />
          <path d="M398 300 l7 0 0 -8 14 -6 0 30 -14 -6 -7 0 z" fill="#ffffff" />
          <rect x="399" y="303" width="6" height="12" rx="2" fill="#ffffff" />

          <!-- Tên thương hiệu -->
          <text x="250" y="372" text-anchor="middle" font-family="Inter, sans-serif" font-weight="800" font-size="27" fill="#ffffff">Sunz Làm Marketing</text>
          <text x="250" y="399" text-anchor="middle" font-family="Inter, sans-serif" font-weight="600" font-size="15" fill="#ffffff" opacity="0.9">@sunzlammarketing</text>
        </svg>
      </div>
    </div>
  </section>

  <!-- Sunz Làm Marketing là ai? -->
  <section class="section me-section" id="sunz-la-ai">
    <div class="container me-grid">
      <div class="me-card">
        <div class="me-avatar">S</div>
        <b class="me-name">Sunz Làm Marketing</b>
        <span class="me-handle">@sunzlammarketing</span>
        <p class="me-bio" data-i18n="home.me.bio">
          Chia sẻ kiến thức, tài liệu & công cụ Marketing miễn phí
        </p>
        <div class="me-links">
          <a href="https://www.instagram.com/sunzlammarketing" target="_blank" rel="noopener">📸 Instagram</a>
          <a href="mailto:sunzlammarketing@gmail.com">✉️ Email</a>
        </div>
      </div>

      <div class="me-text">
        <span class="me-label" data-i18n="home.me.label">Sunz Làm Marketing là ai?</span>
        <h2 class="me-title" data-i18n-html="home.me.title">
          Chào bạn, mình làm Marketing và thích <span class="grad">chia sẻ lại</span>
          những gì đã học.
        </h2>
        <p data-i18n="home.me.p1">
          Marketing có quá nhiều thứ để học. Nhưng phần lớn kiến thức ngoài kia
          hoặc quá hàn lâm, hoặc chỉ là những "mẹo" rời rạc thiếu nền tảng —
          khiến người mới không biết nên bắt đầu từ đâu.
        </p>
        <p data-i18n="home.me.p2">
          Sunz Làm Marketing ra đời để lấp khoảng trống đó. Đây là nơi mình gom
          lại kiến thức, tài liệu và công cụ đã dùng trong công việc, sắp xếp có
          hệ thống từ căn bản đến nâng cao, rồi chia sẻ hoàn toàn miễn phí.
        </p>
        <p data-i18n="home.me.p3">
          Mình không hứa hẹn "làm giàu sau một đêm". Chỉ có kiến thức nền tảng
          vững chắc, ví dụ thực tế, và những thứ bạn áp dụng được ngay vào công
          việc của mình.
        </p>
        <p class="me-closing" data-i18n="home.me.closing">
          Cùng nhau chuẩn bị hành trang thật tốt trước khi bước ra thương trường nhé!
        </p>
        <a href="/gioi-thieu" class="btn btn-ghost me-cta" data-i18n="home.me.cta">Tìm hiểu thêm về Sunz →</a>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="section">
    <div class="container">
      <h2 class="section-title" data-i18n="home.cat.title">Khám phá theo chủ đề</h2>
      <p class="section-sub" data-i18n="home.cat.sub">
        Chọn lĩnh vực bạn quan tâm và đào sâu vào những bài viết chất lượng.
      </p>
      <div class="cat-grid">
        {categories.map((c) => (
          <a href={`/chu-de/${c.slug}`} class="cat-card" style={`--c:${c.color}`}>
            <span class="cat-icon">{c.icon}</span>
            <span class="cat-name" data-i18n-vi={c.name} data-i18n-en={c.nameEn}>{c.name}</span>
            <span class="cat-desc" data-i18n-vi={c.description} data-i18n-en={c.descriptionEn}>{c.description}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Featured -->
  {featured.length > 0 && (
    <section class="section featured-section">
      <div class="container">
        <h2 class="section-title" data-i18n="home.featured.title">Bài viết nổi bật</h2>
        <p class="section-sub" data-i18n="home.featured.sub">Những bài viết mới nhất, đáng đọc nhất tuần này.</p>
        <div class="grid grid-3">
          {featured.map((p) => (
            <PostCard
              slug={p.slug}
              title={p.data.title}
              description={p.data.description}
              pubDate={p.data.pubDate}
              category={p.data.category}
              readingTime={p.data.readingTime}
              lang={p.data.lang}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Recent -->
  <section class="section">
    <div class="container">
      <div class="row-head">
        <div>
          <h2 class="section-title" data-i18n="home.recent.title">Bài viết mới nhất</h2>
          <p class="section-sub" style="margin-bottom:0" data-i18n="home.recent.sub">
            Cập nhật kiến thức marketing đều đặn mỗi tuần.
          </p>
        </div>
        <a href="/blog" class="btn btn-ghost" data-i18n="home.viewall">Xem tất cả →</a>
      </div>
      <div class="grid grid-3" style="margin-top:32px">
        {recent.map((p) => (
          <PostCard
            slug={p.slug}
            title={p.data.title}
            description={p.data.description}
            pubDate={p.data.pubDate}
            category={p.data.category}
            readingTime={p.data.readingTime}
            lang={p.data.lang}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter CTA -->
  <section class="section">
    <div class="container">
      <div class="cta-box">
        <h2 data-i18n="home.cta.title">Đừng bỏ lỡ kiến thức mới</h2>
        <p data-i18n="home.cta.text">
          Ghé thăm thường xuyên hoặc kết nối với chúng tôi để cập nhật những
          bài viết marketing mới nhất.
        </p>
        <a href="/lien-he" class="btn btn-primary" data-i18n="home.cta.btn">Kết nối ngay →</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    position: relative;
    padding-block: 60px 56px;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(50% 60% at 70% 10%, var(--brand-soft), transparent 70%);
    z-index: -1;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    align-items: center;
    gap: 44px;
  }
  .hero-text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 22px;
  }
  .hero h1 {
    font-size: clamp(1.85rem, 3.6vw, 2.85rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.12;
    margin: 0;
    text-align: left;
  }
  .grad {
    background: linear-gradient(120deg, var(--brand), var(--accent));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .hero-sub {
    font-size: 1.12rem;
    color: var(--ink-soft);
    max-width: 540px;
    margin: 0;
  }
  /* Hai nút xếp dọc: nút chính nổi bật, nút phụ nhẹ hơn */
  .hero-actions {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 14px;
  }
  .cta-main {
    padding: 17px 34px;
    font-size: 1rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }
  .cta-sub {
    padding: 13px 28px;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink-soft);
  }
  .cta-sub:hover {
    color: var(--ink);
  }
  .hero-media {
    display: block;
  }
  .hero-illus {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 24px;
    box-shadow: var(--shadow-lg);
  }
  @media (max-width: 900px) {
    .hero-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .hero-text {
      align-items: center;
      text-align: center;
    }
    .hero h1 {
      text-align: center;
    }
    .hero-actions {
      align-items: center;
    }
  }
  /* Mục "Sunz Làm Marketing là ai?" */
  .me-section {
    background: var(--bg-soft);
    border-block: 1px solid var(--border);
    scroll-margin-top: 80px;
  }
  .me-grid {
    display: grid;
    grid-template-columns: 0.8fr 1.2fr;
    gap: 56px;
    align-items: center;
  }
  .me-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 6px;
    padding: 36px 28px;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 22px;
    box-shadow: var(--shadow);
  }
  .me-avatar {
    display: grid;
    place-items: center;
    width: 86px;
    height: 86px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--brand), var(--accent));
    color: #fff;
    font-weight: 900;
    font-size: 2.2rem;
    margin-bottom: 8px;
  }
  .me-name {
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--ink);
  }
  .me-handle {
    font-size: 0.9rem;
    color: var(--ink-faint);
  }
  .me-bio {
    margin: 10px 0 4px;
    font-size: 0.93rem;
    color: var(--ink-soft);
  }
  .me-links {
    display: flex;
    gap: 10px;
    margin-top: 10px;
    flex-wrap: wrap;
    justify-content: center;
  }
  .me-links a {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink-soft);
    border: 1px solid var(--border);
    background: var(--bg-soft);
    padding: 7px 14px;
    border-radius: 999px;
  }
  .me-links a:hover {
    color: var(--brand);
    border-color: var(--brand);
    text-decoration: none;
  }
  .me-label {
    display: block;
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--brand);
    margin-bottom: 14px;
  }
  .me-title {
    font-size: clamp(1.6rem, 3.4vw, 2.4rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.18;
    margin: 0 0 18px;
  }
  .me-text p {
    color: var(--ink-soft);
    font-size: 1.02rem;
    margin: 0 0 14px;
  }
  .me-closing {
    font-weight: 700;
    color: var(--ink) !important;
  }
  .me-cta {
    margin-top: 8px;
  }
  @media (max-width: 860px) {
    .me-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .me-card {
      max-width: 420px;
      margin-inline: auto;
    }
  }

  .cat-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
  }
  .cat-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 24px;
    border-radius: var(--radius);
    border: 1px solid var(--border);
    background: var(--bg-card);
    transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s;
  }
  .cat-card:hover {
    text-decoration: none;
    transform: translateY(-3px);
    box-shadow: var(--shadow);
    border-color: color-mix(in srgb, var(--c) 45%, var(--border));
  }
  .cat-icon {
    font-size: 1.8rem;
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    border-radius: 12px;
    background: color-mix(in srgb, var(--c) 12%, transparent);
  }
  .cat-name {
    font-weight: 700;
    font-size: 1.1rem;
    color: var(--ink);
  }
  .cat-desc {
    color: var(--ink-soft);
    font-size: 0.92rem;
  }

  .featured-section {
    background: var(--bg-soft);
    border-block: 1px solid var(--border);
  }

  .row-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }

  .cta-box {
    text-align: center;
    padding: 56px 24px;
    border-radius: 24px;
    background: linear-gradient(135deg, var(--brand), var(--accent));
    color: #fff;
  }
  .cta-box h2 {
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    font-weight: 800;
    margin: 0 0 10px;
  }
  .cta-box p {
    max-width: 500px;
    margin: 0 auto 24px;
    opacity: 0.95;
  }
  .cta-box .btn-primary {
    background: #fff;
    color: var(--brand-dark);
  }
  .cta-box .btn-primary:hover {
    background: #f0f0f0;
  }

  @media (max-width: 860px) {
    .cat-grid {
      grid-template-columns: 1fr 1fr;
    }
  }
  @media (max-width: 560px) {
    .cat-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
